<section class="signup" data-reveal id="newsletter-{{ section.id }}">
  <p class="type-label">{{ section.settings.eyebrow }}</p>
  <h2 class="type-headline signup__title">{{ section.settings.heading }}</h2>
  {%- if section.settings.text != blank -%}
    <p class="signup__text type-label">{{ section.settings.text }}</p>
  {%- endif -%}

  <div class="signup__form-wrap">
    {%- capture newsletter_form_id -%}NewsletterSection-{{ section.id }}{%- endcapture -%}
    {% render 'newsletter-form', id: newsletter_form_id, button_label: section.settings.button_label %}
  </div>

  {%- if section.settings.link != blank and section.settings.link_label != blank -%}
    <p class="signup__alt type-label">
      <a href="{{ section.settings.link }}" target="_blank" rel="noopener">{{ section.settings.link_label }}</a>
    </p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay Connected" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Sign Up" },
    { "type": "text", "id": "text", "label": "Text", "default": "Tour announcements. New music. Exclusive drops." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Join" },
    { "type": "url", "id": "link", "label": "Secondary link (optional)" },
    { "type": "text", "id": "link_label", "label": "Secondary link label", "default": "More info" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
