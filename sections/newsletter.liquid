<section class="signup" data-reveal>
  <p class="type-label">{{ section.settings.eyebrow }}</p>
  <h2 class="type-headline" style="margin-top:1rem;font-size:clamp(2rem,6vw,4rem);">{{ section.settings.heading }}</h2>
  {%- if section.settings.text != blank -%}
    <p class="type-label" style="margin-top:1.25rem;opacity:0.35;">{{ section.settings.text }}</p>
  {%- endif -%}
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}" class="text-link" target="_blank" rel="noopener">{{ section.settings.link_label }}</a>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay Connected" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Sign Up" },
    { "type": "text", "id": "text", "label": "Text", "default": "Tour announcements. New music. Exclusive drops." },
    { "type": "url", "id": "link", "label": "Signup link" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Join" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
