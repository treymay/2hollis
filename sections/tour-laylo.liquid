<section class="tour-laylo" data-reveal>
  <div class="section-intro">
    <p class="type-label">{{ section.settings.eyebrow }}</p>
    <h1 class="type-headline" style="margin-top:1rem;font-size:clamp(2.5rem,8vw,5rem);">{{ section.settings.heading }}</h1>
  </div>

  <div class="tour-laylo__embed">
    <script src="https://embed.laylo.com/laylo-sdk.js" defer></script>
    <iframe
      id="laylo-drop-{{ section.settings.laylo_drop_id }}"
      title="2hollis tour dates"
      src="https://embed.laylo.com?dropId={{ section.settings.laylo_drop_id }}&color=C8D1DF&minimal=false&theme=dark"
      style="width:1px;min-width:100%;max-width:1000px;border:0;"
      scrolling="no"
      allow="web-share"
      allowtransparency="true"
    ></iframe>
    <div class="tour-laylo__links type-label">
      <a href="{{ section.settings.laylo_profile }}" target="_blank" rel="noopener">Follow 2hollis</a>
      <a href="{{ section.settings.laylo_drop }}" target="_blank" rel="noopener">View on Laylo</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Tour Laylo Embed",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Tickets" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tour" },
    {
      "type": "text",
      "id": "laylo_drop_id",
      "label": "Laylo drop ID",
      "default": "6b824bf7-5f13-490e-b6e7-893a0ce04d31",
      "info": "Laylo drop ID from your Laylo dashboard"
    },
    {
      "type": "text",
      "id": "laylo_profile",
      "label": "Laylo profile URL",
      "default": "https://laylo.com/2hollis"
    },
    {
      "type": "text",
      "id": "laylo_drop",
      "label": "Laylo drop URL",
      "default": "https://laylo.com/d/6b824bf7-5f13-490e-b6e7-893a0ce04d31"
    }
  ],
  "presets": [{ "name": "Tour Laylo Embed" }]
}
{% endschema %}
