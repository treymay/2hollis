<div class="page-shell">
  <div style="padding:calc(var(--header-h) + 4rem) clamp(1.25rem,4vw,3rem) 2rem;text-align:center;">
    <p class="type-label">{{ section.settings.eyebrow }}</p>
    <h1 class="type-headline" style="margin-top:1rem;">{{ section.settings.heading }}</h1>
    <p class="type-label" style="margin-top:1.5rem;opacity:0.35;max-width:560px;margin-inline:auto;">{{ section.settings.description }}</p>
  </div>

  <div class="archive__grid" style="max-width:1400px;margin:0 auto;padding:0 clamp(1rem,3vw,2rem) var(--pad);">
    {%- for block in section.blocks -%}
      <figure class="archive__cell" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: block.settings.caption }}
        {%- elsif block.settings.image_url != blank -%}
          <img src="{{ block.settings.image_url }}" alt="{{ block.settings.caption | escape }}" width="800" height="1000" loading="lazy">
        {%- endif -%}
        {%- if block.settings.caption != blank -%}<span class="archive__tag">{{ block.settings.caption }}</span>{%- endif -%}
      </figure>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Archive Gallery",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Lore" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Archive" },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Old photos. Posters. Flyers. Behind-the-scenes. Unreleased visuals. Scans. Tour photography."
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_url", "label": "Image URL" },
        { "type": "text", "id": "caption", "label": "Caption" }
      ]
    }
  ],
  "presets": [{ "name": "Archive Gallery" }]
}
{% endschema %}
