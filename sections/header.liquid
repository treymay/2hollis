{%- assign menu = section.settings.menu -%}

<header class="site-header type-nav" data-header>
  <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="2HOLLIS">
    {% render 'logo', width: 26, class: 'site-logo site-logo--header' %}
  </a>

  <nav class="site-header__nav" aria-label="Main">
    {%- if menu != blank -%}
      {%- for link in menu.links -%}
        <a href="{{ link.url }}">{{ link.title | escape }}</a>
      {%- endfor -%}
    {%- endif -%}
  </nav>

  <div class="site-header__actions">
    <a href="{{ routes.cart_url }}" class="cart-link type-nav">
      CART{% if cart.item_count > 0 %}<span class="cart-link__count">{{ cart.item_count }}</span>{% endif %}
    </a>
    <button class="site-header__menu-btn" type="button" data-menu-open aria-label="{{ 'general.accessibility.open_menu' | t }}">
      <span></span><span></span>
    </button>
  </div>
</header>

<nav class="mobile-nav type-nav" data-mobile-nav aria-hidden="true">
  <button class="mobile-nav__close" type="button" data-menu-close>{{ 'general.accessibility.close_menu' | t }}</button>
  {%- if menu != blank -%}
    {%- for link in menu.links -%}
      <a href="{{ link.url }}">{{ link.title | escape }}</a>
    {%- endfor -%}
  {%- endif -%}
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
