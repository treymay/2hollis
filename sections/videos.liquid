<section class="videos{% if section.settings.full_page %} videos--page{% endif %}" data-reveal>
  {%- unless section.settings.hide_header -%}
    <div class="section-intro">
      <p class="type-label">{{ section.settings.eyebrow }}</p>
      <h2 class="type-headline" style="margin-top:1rem;">{{ section.settings.heading }}</h2>
    </div>
  {%- endunless -%}

  <div class="videos__grid">
    {%- for block in section.blocks -%}
      {%- assign yt_url = block.settings.video_url -%}
      {%- assign yt_id = '' -%}
      {%- if yt_url contains 'youtu.be/' -%}
        {%- assign yt_id = yt_url | split: 'youtu.be/' | last | split: '?' | first -%}
      {%- elsif yt_url contains 'v=' -%}
        {%- assign yt_id = yt_url | split: 'v=' | last | split: '&' | first -%}
      {%- endif -%}
      <a
        href="{{ block.settings.video_url }}"
        class="video-card"
        target="_blank"
        rel="noopener"
        {{ block.shopify_attributes }}
      >
        <div class="video-card__thumb">
          {%- if block.settings.thumbnail != blank -%}
            {{ block.settings.thumbnail | image_url: width: 1280 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {%- elsif block.settings.thumbnail_url != blank -%}
            <img src="{{ block.settings.thumbnail_url }}" alt="{{ block.settings.title | escape }}" width="1280" height="720" loading="lazy">
          {%- elsif yt_id != blank -%}
            <img src="https://i.ytimg.com/vi/{{ yt_id }}/maxresdefault.jpg" alt="{{ block.settings.title | escape }}" width="1280" height="720" loading="lazy">
          {%- endif -%}
          <span class="video-card__play" aria-hidden="true">▶</span>
        </div>
        <span class="video-card__label">{{ block.settings.title }}</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Videos",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "hide_header", "label": "Hide section header", "default": false },
    { "type": "checkbox", "id": "full_page", "label": "Full page layout", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Visuals" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Video" }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "url", "id": "video_url", "label": "YouTube URL" },
        { "type": "image_picker", "id": "thumbnail", "label": "Thumbnail (optional)" },
        { "type": "text", "id": "thumbnail_url", "label": "Thumbnail URL (optional)" }
      ]
    }
  ],
  "presets": [{ "name": "Videos" }]
}
{% endschema %}
