<section class="videos" data-reveal>
  <div class="section-intro">
    <p class="type-label">{{ section.settings.eyebrow }}</p>
    <h2 class="type-headline" style="margin-top:1rem;">{{ section.settings.heading }}</h2>
  </div>

  <div class="videos__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.video_url }}" class="video-card" target="_blank" rel="noopener" {{ block.shopify_attributes }}>
        <div class="video-card__thumb">
          {%- if block.settings.thumbnail != blank -%}
            {{ block.settings.thumbnail | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {%- elsif block.settings.thumbnail_url != blank -%}
            <img src="{{ block.settings.thumbnail_url }}" alt="{{ block.settings.title | escape }}" width="1200" height="675" loading="lazy">
          {%- endif -%}
        </div>
        <span class="video-card__label">{{ block.settings.title }}</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Videos",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Visuals" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Videos" }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "FLASH" },
        { "type": "url", "id": "video_url", "label": "YouTube URL" },
        { "type": "image_picker", "id": "thumbnail", "label": "Thumbnail" },
        { "type": "text", "id": "thumbnail_url", "label": "Thumbnail URL" }
      ]
    }
  ],
  "presets": [{ "name": "Videos" }]
}
{% endschema %}
