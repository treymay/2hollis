<section class="page-hero{% if section.settings.compact %} page-hero--compact{% endif %}" data-reveal>
  <div class="page-hero__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="type-label">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 class="page-hero__title type-headline">{{ section.settings.heading }}</h1>
    {%- if section.settings.description != blank -%}
      <p class="page-hero__desc">{{ section.settings.description }}</p>
    {%- endif -%}
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="text-link"{% if section.settings.link_external %} target="_blank" rel="noopener"{% endif %}>{{ section.settings.link_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Page Hero",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "compact", "label": "Compact spacing", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "2HOLLIS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Page Title" },
    { "type": "textarea", "id": "description", "label": "Description" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Learn More" },
    { "type": "checkbox", "id": "link_external", "label": "Open link in new tab", "default": false }
  ],
  "presets": [{ "name": "Page Hero" }]
}
{% endschema %}
