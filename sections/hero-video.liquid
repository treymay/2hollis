<section class="hero" data-hero id="hero-{{ section.id }}" aria-label="2HOLLIS">
  <div class="hero__media">
    {%- liquid
      assign poster_url = section.settings.poster_url
      if section.settings.poster_image != blank
        assign poster_url = section.settings.poster_image | image_url: width: 1920
      endif
    -%}

    {%- if poster_url != blank -%}
      <img
        class="hero__poster"
        src="{{ poster_url }}"
        alt=""
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
        data-poster
      >
    {%- endif -%}

    {%- if section.settings.hero_video != blank -%}
      {{ section.settings.hero_video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, preload: 'metadata', class: 'hero__video' }}
    {%- elsif section.settings.video_url != blank -%}
      <video class="hero__video" autoplay muted loop playsinline preload="metadata" aria-hidden="true">
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.youtube_id != blank -%}
      <div class="hero__yt" aria-hidden="true">
        <iframe
          src="https://www.youtube.com/embed/{{ section.settings.youtube_id }}?autoplay=1&mute=1&loop=1&playlist={{ section.settings.youtube_id }}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
          title="2HOLLIS"
          allow="autoplay; encrypted-media"
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>
    {%- endif -%}
  </div>

  <div class="hero__overlay">
    {% render 'logo', width: 120, class: 'site-logo site-logo--hero' %}
  </div>

  <div class="hero__controls">
    {%- if section.settings.hero_video != blank or section.settings.video_url != blank -%}
      <button type="button" class="hero__sound type-nav" data-sound aria-pressed="false">SOUND OFF</button>
    {%- endif -%}
  </div>

  <div class="hero__scroll type-label" aria-hidden="true">Scroll</div>
</section>

{% schema %}
{
  "name": "Hero Video",
  "tag": "section",
  "limit": 1,
  "settings": [
    { "type": "video", "id": "hero_video", "label": "Background video (upload MP4)" },
    { "type": "text", "id": "video_url", "label": "External MP4 URL" },
    {
      "type": "text",
      "id": "youtube_id",
      "label": "YouTube ID (fallback)",
      "default": "nnzndZQX3SU"
    },
    { "type": "image_picker", "id": "poster_image", "label": "Poster image" },
    {
      "type": "text",
      "id": "poster_url",
      "label": "Poster URL (if no image uploaded)",
      "default": "https://www.2hollis.life/wp-content/uploads/sites/2747/2025/02/og2h-compressed.jpg"
    }
  ],
  "presets": [{ "name": "Hero Video" }]
}
{% endschema %}
