<section class="hero" data-hero id="hero-{{ section.id }}" aria-label="2HOLLIS">
  <div class="hero__media">
    {%- liquid
      assign poster_url = section.settings.poster_url
      if section.settings.poster_image != blank
        assign poster_url = section.settings.poster_image | image_url: width: 1920
      endif
    -%}

    {%- if poster_url != blank -%}
      <img
        class="hero__poster"
        src="{{ poster_url }}"
        alt=""
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
        data-poster
      >
    {%- endif -%}

    {%- if section.settings.hero_video != blank -%}
      <div class="hero__video-wrap">
        <video
          class="hero__video"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          aria-hidden="true"
          tabindex="-1"
          disablepictureinpicture
          disableremoteplayback
          controlslist="nodownload noplaybackrate noremoteplayback nofullscreen"
        >
          {%- for source in section.settings.hero_video.sources -%}
            <source src="{{ source.url }}" type="{{ source.mime_type }}">
          {%- endfor -%}
        </video>
      </div>
    {%- elsif section.settings.video_url != blank -%}
      <div class="hero__video-wrap">
        <video
          class="hero__video"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          aria-hidden="true"
          tabindex="-1"
          disablepictureinpicture
          disableremoteplayback
          controlslist="nodownload noplaybackrate noremoteplayback nofullscreen"
        >
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      </div>
    {%- elsif section.settings.youtube_id != blank -%}
      <div class="hero__yt" aria-hidden="true">
        <div
          class="hero__yt-player"
          id="hero-yt-{{ section.id }}"
          data-youtube-id="{{ section.settings.youtube_id }}"
        ></div>
        <div class="hero__yt-shield" aria-hidden="true"></div>
      </div>
    {%- endif -%}
  </div>

  <div class="hero__overlay">
    {% render 'logo', width: 120, class: 'site-logo site-logo--hero' %}
  </div>

  <div class="hero__scroll type-label" aria-hidden="true">Scroll</div>
</section>

{% schema %}
{
  "name": "Hero Video",
  "tag": "section",
  "limit": 1,
  "settings": [
    { "type": "video", "id": "hero_video", "label": "Background video (upload MP4)" },
    { "type": "text", "id": "video_url", "label": "External MP4 URL" },
    {
      "type": "text",
      "id": "youtube_id",
      "label": "YouTube ID (fallback)",
      "default": "nnzndZQX3SU"
    },
    { "type": "image_picker", "id": "poster_image", "label": "Poster image" },
    {
      "type": "text",
      "id": "poster_url",
      "label": "Poster URL (if no image uploaded)",
      "info": "Optional fallback while video loads. Upload a poster image instead when possible."
    }
  ],
  "presets": [{ "name": "Hero Video" }]
}
{% endschema %}
