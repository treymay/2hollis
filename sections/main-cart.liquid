<div class="page-shell">
  <div style="padding:calc(var(--header-h) + 4rem) clamp(1.25rem,4vw,3rem) var(--pad);max-width:720px;margin:0 auto;">
    <p class="type-label">{{ 'cart.general.title' | t }}</p>
    <h1 class="type-headline" style="margin-top:1rem;font-size:clamp(2rem,6vw,3.5rem);">Cart</h1>

    {%- if cart.item_count == 0 -%}
      <p class="type-label" style="margin-top:2.5rem;opacity:0.4;">{{ 'cart.general.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="text-link">{{ 'cart.general.continue_shopping' | t }}</a>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" style="margin-top:2.5rem;">
        {%- for item in cart.items -%}
          <div style="display:flex;gap:1.25rem;padding:1.25rem 0;border-bottom:1px solid rgba(255,255,255,0.07);align-items:center;">
            {%- if item.image -%}
              <div style="width:72px;height:90px;flex-shrink:0;overflow:hidden;background:#111;">
                {{ item.image | image_url: width: 144 | image_tag: alt: item.title }}
              </div>
            {%- endif -%}
            <div style="flex:1;">
              <p style="font-size:10px;letter-spacing:0.2em;text-transform:uppercase;">{{ item.product.title }}</p>
              <p style="opacity:0.4;font-size:10px;margin-top:0.3rem;">{{ item.final_line_price | money }}</p>
            </div>
            <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:44px;padding:0.4rem;background:#111;color:#fff;border:1px solid rgba(255,255,255,0.12);text-align:center;font-size:11px;" aria-label="Quantity">
          </div>
        {%- endfor -%}
        <p class="type-label" style="margin-top:2rem;">Total — {{ cart.total_price | money }}</p>
        <div style="margin-top:1.5rem;display:flex;flex-direction:column;gap:0.75rem;">
          <button type="submit" name="update" class="product__submit" style="background:transparent;border:1px solid rgba(255,255,255,0.2);color:#fff;">{{ 'cart.general.update' | t }}</button>
          <button type="submit" name="checkout" class="product__submit">{{ 'cart.general.checkout' | t }}</button>
        </div>
      </form>
    {%- endif -%}
  </div>
</div>

{% schema %}
{ "name": "Cart", "tag": "section", "settings": [] }
{% endschema %}
