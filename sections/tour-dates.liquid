<section class="tour" data-reveal id="tour-{{ section.id }}">
  <div class="section-intro">
    <p class="type-label">{{ section.settings.eyebrow }}</p>
    <h2 class="type-headline" style="margin-top:1rem;">{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="type-label" style="margin-top:1rem;opacity:0.35;">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <ul class="tour__list">
    {%- for block in section.blocks -%}
      <li class="tour__row" {{ block.shopify_attributes }}>
        {%- if block.settings.ticket_url != blank -%}
          <a href="{{ block.settings.ticket_url }}" class="tour__link" target="_blank" rel="noopener">
        {%- else -%}
          <div class="tour__link">
        {%- endif -%}
          <span class="tour__city">{{ block.settings.city }}</span>
          <span class="tour__detail">
            <span class="tour__date">{{ block.settings.date }}</span>
            {%- if block.settings.venue != blank -%}<span class="tour__venue">{{ block.settings.venue }}</span>{%- endif -%}
          </span>
        {%- if block.settings.ticket_url != blank -%}</a>{%- else -%}</div>{%- endif -%}
      </li>
    {%- endfor -%}
  </ul>

  <div class="tour__footer">
    {%- if section.settings.all_dates_link != blank -%}
      <a href="{{ section.settings.all_dates_link }}" class="text-link" style="margin-top:0;">{{ section.settings.all_dates_label }}</a>
    {%- endif -%}
    {%- if section.settings.vip_link != blank -%}
      <a href="{{ section.settings.vip_link }}" class="text-link" style="margin-top:0;" target="_blank" rel="noopener">{{ section.settings.vip_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Tour Dates",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "On Tour" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Star Tour" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "2026" },
    { "type": "text", "id": "all_dates_link", "label": "All dates link", "default": "/pages/tour", "info": "Relative path or full URL" },
    { "type": "text", "id": "all_dates_label", "label": "All dates label", "default": "All Dates" },
    { "type": "url", "id": "vip_link", "label": "VIP link" },
    { "type": "text", "id": "vip_label", "label": "VIP label", "default": "VIP Experience" }
  ],
  "blocks": [
    {
      "type": "date",
      "name": "Date",
      "settings": [
        { "type": "text", "id": "city", "label": "City", "default": "NEW YORK" },
        { "type": "text", "id": "date", "label": "Date", "default": "JUN 05 2026" },
        { "type": "text", "id": "venue", "label": "Venue" },
        { "type": "url", "id": "ticket_url", "label": "Tickets URL" }
      ]
    }
  ],
  "presets": [{ "name": "Tour Dates" }]
}
{% endschema %}
