<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} — {{ 'general.password_page.opening_soon' | t }}</title>
  {{ content_for_header }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
</head>
<body class="template-password" style="min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:2rem;">
  <div>
    <p class="type-label" style="font-size:11px;letter-spacing:0.35em;text-transform:uppercase;">2HOLLIS</p>
    <h1 style="font-weight:200;letter-spacing:0.15em;text-transform:uppercase;margin:1.5rem 0 2rem;font-size:clamp(1.5rem,5vw,2.5rem;">{{ shop.name }}</h1>
    {% form 'storefront_password' %}
      {{ form.errors | default_errors }}
      <label class="visually-hidden" for="password">{{ 'general.password_page.login_form_password_label' | t }}</label>
      <input
        type="password"
        name="password"
        id="password"
        placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}"
        style="background:#111;border:1px solid rgba(255,255,255,0.15);color:#fff;padding:0.85rem 1rem;width:min(100%,280px);letter-spacing:0.1em;font-size:11px;text-transform:uppercase;"
      >
      <button type="submit" style="display:block;margin:1rem auto 0;padding:0.85rem 2rem;background:#fff;color:#000;letter-spacing:0.25em;text-transform:uppercase;font-size:10px;border:none;cursor:pointer;">
        {{ 'general.password_page.login_form_submit' | t }}
      </button>
    {% endform %}
  </div>
</body>
</html>
